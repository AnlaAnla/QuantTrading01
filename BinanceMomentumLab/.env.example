APP_MODE=PAPER
BINANCE_MAINNET_REST_URL=https://fapi.binance.com
BINANCE_MAINNET_WS_URL=wss://fstream.binance.com
BINANCE_DEMO_REST_URL=https://demo-fapi.binance.com
BINANCE_DEMO_WS_URL=wss://fstream.binancefuture.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
PAPER_INITIAL_BALANCE=10000
LIVE_TRADING_ENABLED=false
DEMO_TRADING_ENABLED=false

# Scanner
SCAN_INTERVAL_SECONDS=10
MIN_24H_QUOTE_VOLUME=100000000
MIN_24H_PRICE_CHANGE_PERCENT=5
MIN_5M_PRICE_CHANGE_PERCENT=2
MIN_5M_VOLUME_ZSCORE=3
VOLUME_BASELINE_WINDOWS=60
MAX_CANDIDATES=20
KLINE_CONCURRENCY=8

# Runtime
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
DATABASE_PATH=data/binance_momentum.duckdb
LOG_LEVEL=INFO
DEMO_DATA=false

# Real-time market data
WS_ROTATION_SECONDS=85800
WS_RECONNECT_BASE_SECONDS=1
WS_RECONNECT_MAX_SECONDS=30
WS_QUEUE_MAXSIZE=10000
WS_STALE_AFTER_SECONDS=3
WS_PING_INTERVAL_SECONDS=180
WS_PING_TIMEOUT_SECONDS=600
ORDER_BOOK_DEPTH_LIMIT=1000
PARQUET_ROOT=data/raw_events
PARQUET_BATCH_SIZE=1000
PARQUET_FLUSH_SECONDS=5

# Feature engine
FEATURE_VOLUME_BASELINE_WINDOWS=60
FEATURE_CVD_WINDOW_SECONDS=300
FEATURE_OI_WINDOW_SECONDS=300
FEATURE_BENCHMARK_SYMBOL=BTCUSDT
FEATURE_BTC_BETA=1
OI_POLL_INTERVAL_SECONDS=15

# Strategy state machine (percentage values use percentage-point units)
STRATEGY_WATCH_RETURN_5M_PERCENT=1.5
STRATEGY_WATCH_VOLUME_ZSCORE=2.5
STRATEGY_IGNITION_RETURN_5M_PERCENT=3
STRATEGY_LONG_VOLUME_ZSCORE=4
STRATEGY_LONG_TAKER_BUY_RATIO=0.58
STRATEGY_LONG_OI_CHANGE_5M_PERCENT=1
STRATEGY_MAX_SPREAD_BPS=8
STRATEGY_PULLBACK_MIN_RATIO=0.20
STRATEGY_PULLBACK_MAX_RATIO=0.50
STRATEGY_PULLBACK_VOLUME_RATIO_MAX=0.80
STRATEGY_BUY_ABSORPTION_TAKER_RATIO=0.60
STRATEGY_BUY_ABSORPTION_MAX_RETURN_1M_PERCENT=0.10
STRATEGY_SHORT_TAKER_SELL_RATIO=0.55
STRATEGY_COOLDOWN_SECONDS=1800

# Paper broker and risk manager
PAPER_TAKER_FEE_RATE=0.0004
PAPER_NETWORK_LATENCY_MS=100
PAPER_BASE_SLIPPAGE_BPS=1
PAPER_VOLATILITY_SLIPPAGE_FACTOR=0.20
PAPER_SPREAD_SLIPPAGE_FACTOR=0.25
PAPER_NOTIONAL_SLIPPAGE_BPS_PER_100K=1
PAPER_TAKE_PROFIT_R_MULTIPLE=2
PAPER_MAX_HOLD_SECONDS=900
PAPER_QUANTITY_STEP=0.001
RISK_PER_TRADE_FRACTION=0.0025
RISK_MAX_POSITIONS=1
RISK_MAX_DAILY_LOSS_FRACTION=0.01
RISK_CONSECUTIVE_LOSS_LIMIT=3
RISK_COOLDOWN_SECONDS=1800
RISK_DATA_MAX_AGE_SECONDS=3
RISK_MAX_POSITION_NOTIONAL_MULTIPLE=1
