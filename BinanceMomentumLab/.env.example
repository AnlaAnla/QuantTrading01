APP_MODE=PAPER
BINANCE_MAINNET_REST_URL=https://fapi.binance.com
BINANCE_MAINNET_WS_URL=wss://fstream.binance.com
BINANCE_DEMO_REST_URL=https://demo-fapi.binance.com
BINANCE_DEMO_WS_URL=wss://fstream.binancefuture.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
PAPER_INITIAL_BALANCE=10000
LIVE_TRADING_ENABLED=false
DEMO_TRADING_ENABLED=false

# Scanner
SCAN_INTERVAL_SECONDS=10
MIN_24H_QUOTE_VOLUME=100000000
MIN_24H_PRICE_CHANGE_PERCENT=5
MIN_5M_PRICE_CHANGE_PERCENT=2
MIN_5M_VOLUME_ZSCORE=3
VOLUME_BASELINE_WINDOWS=60
MAX_CANDIDATES=20
KLINE_CONCURRENCY=8

# Runtime
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
DATABASE_PATH=data/binance_momentum.duckdb
LOG_LEVEL=INFO
DEMO_DATA=false

